<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
	<dict>
		<!-- ── Bundle identity ─────────────────────────────────────────────── -->
		<key>CFBundleDevelopmentRegion</key>
		<string>$(DEVELOPMENT_LANGUAGE)</string>
		<key>CFBundleDisplayName</key>
		<string>$(FLAVOR_APP_NAME)</string>
		<key>CFBundleExecutable</key>
		<string>$(EXECUTABLE_NAME)</string>
		<key>CFBundleIdentifier</key>
		<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
		<key>CFBundleInfoDictionaryVersion</key>
		<string>6.0</string>
		<key>CFBundleName</key>
		<string>$(FLAVOR_APP_NAME)</string>
		<key>CFBundlePackageType</key>
		<string>APPL</string>
		<key>CFBundleShortVersionString</key>
		<string>$(FLUTTER_BUILD_NAME)</string>
		<key>CFBundleSignature</key>
		<string>????</string>
		<key>CFBundleVersion</key>
		<string>$(FLUTTER_BUILD_NUMBER)</string>

		<!-- ── Supported languages (all languages Naiia serves) ────────────── -->
		<key>CFBundleLocalizations</key>
		<array>
			<string>en</string>
			<string>ar</string>
			<string>fr</string>
		</array>

		<!-- ── Device / orientation ────────────────────────────────────────── -->
		<key>LSRequiresIPhoneOS</key>
		<true/>
		<key>UISupportedInterfaceOrientations</key>
		<array>
			<string>UIInterfaceOrientationPortrait</string>
		</array>
		<key>UISupportedInterfaceOrientations~ipad</key>
		<array>
			<string>UIInterfaceOrientationPortrait</string>
			<string>UIInterfaceOrientationPortraitUpsideDown</string>
			<string>UIInterfaceOrientationLandscapeLeft</string>
			<string>UIInterfaceOrientationLandscapeRight</string>
		</array>

		<!-- ── UI / display ────────────────────────────────────────────────── -->
		<key>UILaunchStoryboardName</key>
		<string>LaunchScreen</string>
		<key>UIMainStoryboardFile</key>
		<string>Main</string>
		<key>UIViewControllerBasedStatusBarAppearance</key>
		<false/>
		<key>UIStatusBarHidden</key>
		<false/>
		<!-- Enable ProMotion (120 Hz) on supported iPhones -->
		<key>CADisableMinimumFrameDurationOnPhone</key>
		<true/>
		<!-- Required for indirect input (trackpad / keyboard on iPad) -->
		<key>UIApplicationSupportsIndirectInputEvents</key>
		<true/>

		<!-- ── Background modes ─────────────────────────────────────────────── -->
		<!-- Needed for audioplayers to keep playing while app is backgrounded  -->
		<key>UIBackgroundModes</key>
		<array>
			<string>audio</string>
		</array>

		<!-- ── Privacy usage descriptions (required by App Store Review) ────── -->
		<key>NSCameraUsageDescription</key>
		<string>Naiia uses your camera to scan medication labels and barcodes so you can get instant information about your medicines.</string>
		<key>NSMicrophoneUsageDescription</key>
		<string>Naiia uses your microphone so you can ask health questions by voice and receive spoken answers.</string>
		<key>NSPhotoLibraryUsageDescription</key>
		<string>Naiia accesses your photo library so you can choose an existing image of a medication label for analysis.</string>
		<key>NSPhotoLibraryAddUsageDescription</key>
		<string>Naiia may save medication scan results to your photo library for your records.</string>
		<key>NSDocumentsFolderUsageDescription</key>
		<string>Naiia accesses your documents so you can upload prescription PDFs or medical letters for analysis.</string>

		<!-- ── App Store encryption declaration ─────────────────────────────── -->
		<!-- The app uses standard HTTPS (TLS) only — no custom encryption.     -->
		<!-- This exempts the app from EAR export compliance filings.           -->
		<key>ITSAppUsesNonExemptEncryption</key>
		<false/>
	</dict>
</plist>
